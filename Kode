// API RUMAH DINAS (MENU BARU)
// ==========================================
function handleGetDinas(p) {
  const data = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAMES.DATA_DINAS).getDataRange().getValues();
  let result = [];
  for (let i = 1; i < data.length; i++) {
    let item = {
      id: data[i][0], petugas_username: data[i][1], nama_penghuni: data[i][2], nik: data[i][3], no_kk: data[i][4],
      nama_instansi: data[i][5], dusun: data[i][6], desa: data[i][7], kecamatan: data[i][8], created_at: data[i][9]
    };
    // Petugas kampung hanya lihat data yang diinputnya, admin/kecamatan bisa lihat semua
    if (p.role === 'petugas' && item.petugas_username !== p.username) continue;
    result.push(item);
  }
  return { status: 'success', data: result.reverse() };
}

function handleSaveDinas(p) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAMES.DATA_DINAS);
  const d = p.data;
  
  if (p.id) {
    const data = sheet.getDataRange().getValues();
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] == p.id) {
        sheet.getRange(i + 1, 3, 1, 7).setValues([[d.nama_penghuni, d.nik, d.no_kk, d.nama_instansi, d.dusun, d.desa, d.kecamatan]]);
        return { status: 'success' };
      }
    }
    throw new Error("Data tidak ditemukan");
  } else {
    const newId = Date.now().toString();
    sheet.appendRow([newId, p.username, d.nama_penghuni, d.nik, d.no_kk, d.nama_instansi, d.dusun, d.desa, d.kecamatan, new Date().toISOString()]);
    return { status: 'success' };
  }
}

function handleDeleteDinas(p) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAMES.DATA_DINAS);
  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (data[i][0] == p.id) {
      sheet.deleteRow(i + 1);
      return { status: 'success' };
    }
  }
  throw new Error("Gagal menghapus");
}
