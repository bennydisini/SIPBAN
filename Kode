const SPREADSHEET_ID = SpreadsheetApp.getActiveSpreadsheet().getId();
const FOLDER_NAME_FOTO = "SIPBAN_Foto_Kerusakan";
const SHEET_NAMES = {
  USERS: 'users',
  DATA_RUMAH: 'data_rumah',
  DATA_BANTUAN: 'data_bantuan',
